# ---------- Server ----------
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ---------- Database (MongoDB via Prisma) ----------
# Must be a replica set for Prisma transactions to work (use MongoDB Atlas or a local rs)
DATABASE_URL="mongodb+srv://Arshad:arshad12%4034@cluster0.piuzs.mongodb.net/applifylab?retryWrites=true&w=majority"

# ---------- Redis (optional) ----------
# REDIS_URL="redis://localhost:6379"
# If not set, the app runs with in-memory rate limiting and no caching (suitable for development/assessment).
# Uncomment and configure to enable distributed rate limiting and caching.
REDIS_CACHE_TTL_FEED_SECONDS=30
REDIS_CACHE_TTL_POST_SECONDS=60

# ---------- JWT ----------
JWT_ACCESS_SECRET="replace-with-32-byte-random-secret-access"
JWT_REFRESH_SECRET="replace-with-32-byte-random-secret-refresh"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Security ----------
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ---------- Storage (image URLs) ----------
# Real projects would point this at S3 / GCS / Cloudinary; this backend only stores/validates URLs.
STORAGE_PUBLIC_BASE_URL="https://cdn.example.com"

# ---------- Pagination ----------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=50

# ---------- Logging ----------
LOG_LEVEL=info

# ---------- Cloudinary ----------
